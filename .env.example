# AlphaCota - Environment Variables
# Copy this file to .env and fill in the values

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# Application secret key (for JWT token signing) — REQUIRED
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Database path (optional, defaults to alphacota.db)
# DATABASE_PATH=alphacota.db

# ---------------------------------------------------------------------------
# AI Providers
# ---------------------------------------------------------------------------

# Groq API (fast inference for news/sentiment)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API (DeepSeek R1 for probability estimation)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------------------------------------------------------
# Polymarket — Operational (non-sensitive)
# ---------------------------------------------------------------------------

# Mode: "paper" (no real money) or "live" (real USDC on Polygon)
POLYMARKET_MODE=paper

# Maximum USD per position (hardcoded to $50 for first week of live trading)
POLYMARKET_MAX_POSITION_USD=50.0

# Maximum daily loss in USD before kill-switch triggers
POLYMARKET_MAX_DAILY_LOSS_USD=10.0

# Polygon RPC via Alchemy or Infura (public endpoints blocked on Contabo Frankfurt)
# Get your key at: https://dashboard.alchemy.com
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_key_here

# Main loop interval in seconds (default: 300 = 5 minutes)
# LOOP_INTERVAL_SECONDS=300

# ---------------------------------------------------------------------------
# Polymarket — Secrets (sensitive — never commit these)
# ---------------------------------------------------------------------------

# CLOB API credentials (from https://polymarket.com/profile)
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_API_SECRET=your_polymarket_api_secret_here

# Wallet private key — AES-256-GCM encrypted hex (use secrets_vault.py to encrypt)
# Never store the raw private key here — always encrypt via: python -m core.secrets_vault
POLYMARKET_PRIVATE_KEY_ENC=

# Polygonscan API key for on-chain wallet tracking (copy-trading)
# Get your key at: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
